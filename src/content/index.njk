---
layout: page.njk
title: Home
permalink: /
seoTitle: "AI Safety for Italy"
seoDescription: "AI Safety for Italy is Italy's grassroots community reducing risks from advanced AI through awareness, education, and collaboration. Open to researchers, students, and professionals."
---

<!-- Hero Section -->
<section class="hero">
    <div class="container text-center relative z-10" style="max-width: 70rem;">
        <h1 class="hero-title rise" data-en="{{ translations.en.hero.title }}" data-it="{{ translations.it.hero.title }}">{{ translations.en.hero.title }}</h1>
        <p class="hero-sub rise text-xl md:text-2xl max-w-4xl mx-auto" data-en="{{ translations.en.hero.subtitle }}" data-it="{{ translations.it.hero.subtitle }}">{{ translations.en.hero.subtitle }}</p>
        <p class="hero-sub rise text-lg max-w-4xl mx-auto mt-4" data-en="{{ translations.en.hero.description }}" data-it="{{ translations.it.hero.description }}">{{ translations.en.hero.description }}</p>
        <div class="rise flex flex-col sm:flex-row gap-4 justify-center mt-8">
            <a href="{{ home.hero.cta_link }}" class="btn btn-primary btn-lg" data-en="{{ translations.en.hero.cta }}" data-it="{{ translations.it.hero.cta }}">{{ translations.en.hero.cta }}</a>
            <a href="{{ home.hero.secondary_cta_link }}" class="btn btn-secondary btn-lg" data-en="{{ translations.en.hero.secondary_cta }}" data-it="{{ translations.it.hero.secondary_cta }}">{{ translations.en.hero.secondary_cta }}</a>
        </div>
    </div>
</section>

{% include "news-carousel.njk" %}

<!-- What We Do -->
<section class="section" id="learn-more" style="background-color: var(--bg-primary);">
    <div class="container">
        <div class="text-center mb-14 max-w-2xl mx-auto">
            <h2 data-en="Three ways we build a safer AI ecosystem" data-it="Tre modi in cui costruiamo un ecosistema AI più sicuro">Three ways we build a safer AI ecosystem</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {% set tints = ["green", "lavender", "cream"] %}
            {% set icons = ["graduation", "handshake", "flask"] %}
            {% for feature in home.features %}
            <div class="feature-card tint-{{ tints[loop.index0] }} reveal">
                <span class="feature-icon"><svg class="ds-icon" aria-hidden="true"><use href="#icon-{{ icons[loop.index0] }}"></use></svg></span>
                <h3 class="mb-2">{{ feature.title }}</h3>
                <p style="margin-bottom: 0;">{{ feature.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Mission Split -->
<section class="section" style="background-color: var(--bg-secondary);">
    <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
            <div class="card-elevated reveal">
                <h3 class="mb-3">{{ home.mission.problem_title }}</h3>
                <p>{{ home.mission.problem_description | split('\n\n') | first }}</p>
                <p style="margin-bottom: 0;">{{ home.mission.problem_description | split('\n\n') | last }}</p>
            </div>
            <div class="card-elevated reveal">
                <h3 class="mb-3">{{ home.mission.solution_title }}</h3>
                <p>{{ home.mission.solution_description | split('\n\n') | first }}</p>
                <a href="{{ site.forms.mailingList }}" target="_blank" class="btn btn-primary mt-2" style="align-self: flex-start;" data-en="Get involved today" data-it="Partecipa oggi">Get involved today</a>
            </div>
        </div>
    </div>
</section>

{% include "contact-form.njk" %}

<!-- CTA Section -->
<section class="section">
    <div class="container">
        <div class="cta-panel reveal">
            <h2 data-en="{{ translations.en.cta.title }}" data-it="{{ translations.it.cta.title }}">{{ translations.en.cta.title }}</h2>
            <p data-en="{{ translations.en.cta.description }}" data-it="{{ translations.it.cta.description }}">{{ translations.en.cta.description }}</p>
            <a href="{{ site.forms.mailingList }}" target="_blank" class="btn btn-primary btn-lg" data-en="{{ translations.en.cta.button }}" data-it="{{ translations.it.cta.button }}">{{ translations.en.cta.button }}</a>
        </div>
    </div>
</section>
