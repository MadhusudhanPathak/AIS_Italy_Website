<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#3b82f6" />

  {# ── Core SEO ────────────────────────────────────────────────── #}
  <title>{% if seoTitle %}{{ seoTitle }}{% else %}{{ title }} | AI Safety Italia{% endif %}</title>
  <meta name="description" content="{% if seoDescription %}{{ seoDescription }}{% elif description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
  <meta name="author" content="AI Safety Italia" />

  {# ── Canonical URL ───────────────────────────────────────────── #}
  <link rel="canonical" href="https://aisafetycommunity.it{{ page.url }}" />

  {# ── hreflang (EN / IT) ──────────────────────────────────────── #}
  <link rel="alternate" hreflang="en" href="https://aisafetycommunity.it{{ page.url }}" />
  <link rel="alternate" hreflang="it" href="https://aisafetycommunity.it/it{{ page.url }}" />
  <link rel="alternate" hreflang="x-default" href="https://aisafetycommunity.it{{ page.url }}" />

  {# ── Open Graph ──────────────────────────────────────────────── #}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="AI Safety Italia" />
  <meta property="og:title" content="{% if seoTitle %}{{ seoTitle }}{% else %}{{ title }} | AI Safety Italia{% endif %}" />
  <meta property="og:description" content="{% if seoDescription %}{{ seoDescription }}{% elif description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
  <meta property="og:url" content="https://aisafetycommunity.it{{ page.url }}" />
  <meta property="og:image" content="https://aisafetycommunity.it/assets/img/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="AI Safety Italia — Building a safer future through awareness, education, and community" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:locale:alternate" content="it_IT" />

  {# ── Twitter / X Card ────────────────────────────────────────── #}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{% if seoTitle %}{{ seoTitle }}{% else %}{{ title }} | AI Safety Italia{% endif %}" />
  <meta name="twitter:description" content="{% if seoDescription %}{{ seoDescription }}{% elif description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
  <meta name="twitter:image" content="https://aisafetycommunity.it/assets/img/og-image.png" />

  {# ── Favicon ─────────────────────────────────────────────────── #}
  <link rel="icon" type="image/svg+xml" href="/assets/img/AISafetyItaly.svg" />

  {# ── Preload logo SVG ────────────────────────────────────────── #}
  <link rel="preload" as="image" href="/assets/img/AISafetyItaly.svg" />

  {# ── CSS ─────────────────────────────────────────────────────── #}
  <link rel="stylesheet" href="/assets/css/style.css" />

  {# ══════════════════════════════════════════════════════════════
     STRUCTURED DATA (JSON-LD)
     Each block only outputs on the matching page URL
     ══════════════════════════════════════════════════════════════ #}

  {# Homepage: Organization + WebSite #}
  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://aisafetycommunity.it/#organization",
        "name": "AI Safety Italia",
        "alternateName": ["AI Safety Italy"],
        "url": "https://aisafetycommunity.it/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://aisafetycommunity.it/assets/img/AISafetyItaly.svg"
        },
        "description": "Italy's grassroots community reducing risks from advanced AI through awareness, education, and collaboration.",
        "knowsAbout": ["AI safety", "AI alignment", "AI governance", "Existential risk from AI", "Machine learning interpretability"],
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "aisafetyitalia@gmail.com",
          "contactType": "general"
        },
        "sameAs": [
          "https://www.linkedin.com/company/ai-safety-italia/",
          "https://discord.gg/aYNAPZjQJu"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://aisafetycommunity.it/#website",
        "url": "https://aisafetycommunity.it/",
        "name": "AI Safety Italia",
        "inLanguage": ["en", "it"],
        "publisher": { "@id": "https://aisafetycommunity.it/#organization" }
      }
    ]
  }
  </script>
  {% endif %}

  {# About page #}
  {% if page.url == "/about/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "url": "https://aisafetycommunity.it/about/",
    "name": "About AI Safety Italia",
    "isPartOf": { "@id": "https://aisafetycommunity.it/#website" },
    "about": { "@id": "https://aisafetycommunity.it/#organization" }
  }
  </script>
  {% endif %}

  {# FAQ page: enables Google FAQ rich results #}
  {% if page.url == "/faq/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "url": "https://aisafetycommunity.it/faq/",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is AI safety?",
        "acceptedAnswer": { "@type": "Answer", "text": "AI safety is the field of research focused on ensuring AI systems behave in ways that are beneficial to humanity, preventing unintended consequences and aligning AI goals with human values." }
      },
      {
        "@type": "Question",
        "name": "What does AI Safety Italia do?",
        "acceptedAnswer": { "@type": "Answer", "text": "AI Safety Italia is a grassroots community running seminars, study groups, mentorship programs, and networking events in Italy. It operates through 9 working groups covering mentorship, governance, technical infrastructure, education, and more." }
      },
      {
        "@type": "Question",
        "name": "Who can join AI Safety Italia?",
        "acceptedAnswer": { "@type": "Answer", "text": "Anyone interested in AI safety is welcome — researchers, students, and professionals from any field. We believe diverse perspectives are essential for addressing AI safety challenges." }
      },
      {
        "@type": "Question",
        "name": "How can I join AI Safety Italia?",
        "acceptedAnswer": { "@type": "Answer", "text": "Fill in the interest form at https://aisafetycommunity.it/community/ — it takes about 5 minutes. Indicate which working groups you'd like to join and how many hours per month you can commit." }
      },
      {
        "@type": "Question",
        "name": "Is AI Safety Italia affiliated with any institution?",
        "acceptedAnswer": { "@type": "Answer", "text": "AI Safety Italia is an independent grassroots organization. We collaborate with universities and international AI safety organizations, but operate independently to serve the Italian community." }
      }
    ]
  }
  </script>
  {% endif %}

  {# Community page #}
  {% if page.url == "/community/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "url": "https://aisafetycommunity.it/community/",
    "name": "AI Safety Italia Community — Members and Working Groups",
    "isPartOf": { "@id": "https://aisafetycommunity.it/#website" },
    "about": {
      "@type": "Organization",
      "@id": "https://aisafetycommunity.it/#organization",
      "department": [
        { "@type": "Organization", "name": "Mentorship Working Group" },
        { "@type": "Organization", "name": "Governance and Fundraising Working Group" },
        { "@type": "Organization", "name": "Communications Working Group" },
        { "@type": "Organization", "name": "Technical Infrastructure Working Group" },
        { "@type": "Organization", "name": "Events Working Group" },
        { "@type": "Organization", "name": "Education and Outreach Working Group" }
      ]
    }
  }
  </script>
  {% endif %}

  {# Contact page #}
  {% if page.url == "/contact/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "url": "https://aisafetycommunity.it/contact/",
    "name": "Contact AI Safety Italia",
    "isPartOf": { "@id": "https://aisafetycommunity.it/#website" },
    "mainEntity": {
      "@type": "Organization",
      "@id": "https://aisafetycommunity.it/#organization",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "aisafetyitalia@gmail.com",
        "contactType": "general",
        "availableLanguage": ["English", "Italian"]
      }
    }
  }
  </script>
  {% endif %}

  {# Optional: any page can inject extra <head> content via frontmatter extraHead #}
  {% if extraHead %}{{ extraHead | safe }}{% endif %}

</head>
<body style="background-color: var(--bg-primary); color: var(--text-primary);">
    {% include "header.njk" %}

    <main id="main" class="min-h-screen">
        {{ content | safe }}
    </main>

    {% include "footer.njk" %}

    <script>
        // DOM ready function
        function domReady(callback) {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', callback);
            } else {
                callback();
            }
        }

        // Toggle mobile menu with error handling
        function toggleMenu() {
            try {
                const menu = document.getElementById('mobileMenu');
                const btn = document.getElementById('menuToggle');
                
                if (!menu || !btn) {
                    console.error('Mobile menu elements not found');
                    return;
                }
                
                const isHidden = menu.classList.contains('hidden');
                if (isHidden) {
                    menu.classList.remove('hidden');
                    btn.setAttribute('aria-expanded', 'true');
                    // Focus first element in menu for accessibility
                    const firstFocusable = menu.querySelector('a, button, input');
                    if (firstFocusable) {
                        firstFocusable.focus();
                    }
                } else {
                    menu.classList.add('hidden');
                    btn.setAttribute('aria-expanded', 'false');
                    btn.focus(); // Return focus to menu button
                }
            } catch (error) {
                console.error('Error toggling menu:', error);
            }
        }

        // Close mobile menu when clicking outside
        function setupOutsideClickHandler() {
            try {
                document.addEventListener('click', function (e) {
                    const menu = document.getElementById('mobileMenu');
                    const btn = document.getElementById('menuToggle');
                    
                    if (!menu || !btn) return;
                    
                    if (!menu.classList.contains('hidden')) {
                        if (!menu.contains(e.target) && !btn.contains(e.target)) {
                            menu.classList.add('hidden');
                            btn.setAttribute('aria-expanded', 'false');
                        }
                    }
                });
            } catch (error) {
                console.error('Error setting up outside click handler:', error);
            }
        }

        // Initialize when DOM is ready
        domReady(function() {
            setupOutsideClickHandler();
            
            // Add error handling for potential JavaScript issues
            window.addEventListener('error', function(e) {
                console.error('JavaScript error:', e.error);
            });
        });

        // Enhanced keyboard navigation
        document.addEventListener('keydown', function(e) {
            // Close menu with Escape key
            if (e.key === 'Escape') {
                const menu = document.getElementById('mobileMenu');
                const btn = document.getElementById('menuToggle');

                if (menu && !menu.classList.contains('hidden')) {
                    menu.classList.add('hidden');
                    btn.setAttribute('aria-expanded', 'false');
                    btn.focus();
                }
            }
        });

        // Theme toggle functionality
        function initThemeToggle() {
            const themeToggleBtn = document.getElementById('theme-toggle');
            const themeIcon = document.getElementById('theme-icon');
            const currentTheme = localStorage.getItem('theme') || '{{ design.themes.dark.isDefault == true and "dark" or "light" }}';

            // Apply saved theme on page load
            if (currentTheme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                themeIcon.textContent = '{{ design.themes.toggle.icon.light | default("☀️") }}'; // Sun icon for light mode
            } else {
                document.documentElement.removeAttribute('data-theme');
                themeIcon.textContent = '{{ design.themes.toggle.icon.dark | default("🌙") }}'; // Moon icon for dark mode
            }

            // Update background images based on theme
            function updateBackgroundImages() {
                const heroBgs = document.querySelectorAll('.hero-background');
                heroBgs.forEach(heroBg => {
                    if (document.documentElement.getAttribute('data-theme') === 'dark') {
                        heroBg.style.backgroundImage = 'url("/assets/img/ais_italy_dark_bg.png")';
                    } else {
                        heroBg.style.backgroundImage = 'url("/assets/img/ais_italy.jpg")';
                    }
                });
                
                // Also update any other themed backgrounds if needed
                const themedElements = document.querySelectorAll('[data-theme-bg]');
                themedElements.forEach(element => {
                    const lightBg = element.getAttribute('data-theme-bg-light');
                    const darkBg = element.getAttribute('data-theme-bg-dark');
                    
                    if (document.documentElement.getAttribute('data-theme') === 'dark') {
                        if (darkBg) element.style.backgroundImage = `url("${darkBg}")`;
                    } else {
                        if (lightBg) element.style.backgroundImage = `url("${lightBg}")`;
                    }
                });
            }

            // Initialize background images
            updateBackgroundImages();

            // Add click event to toggle theme
            if (themeToggleBtn) {
                themeToggleBtn.addEventListener('click', function() {
                    const currentThemeAttr = document.documentElement.getAttribute('data-theme');

                    if (currentThemeAttr === 'dark') {
                        // Switch to light mode
                        document.documentElement.removeAttribute('data-theme');
                        localStorage.setItem('theme', 'light');
                        themeIcon.textContent = '🌙';
                    } else {
                        // Switch to dark mode
                        document.documentElement.setAttribute('data-theme', 'dark');
                        localStorage.setItem('theme', 'dark');
                        themeIcon.textContent = '☀️';
                    }

                    // Update background images after theme change
                    updateBackgroundImages();
                });
            }
        }

        // Initialize theme toggle when DOM is ready
        domReady(initThemeToggle);

        // ── Language toggle ──────────────────────────────────────────────────
        function applyLanguage(lang) {
            document.querySelectorAll('[data-en][data-it]').forEach(el => {
                el.textContent = el.getAttribute('data-' + lang);
            });
            // placeholder attrs on inputs/selects
            document.querySelectorAll('[data-placeholder-en][data-placeholder-it]').forEach(el => {
                el.placeholder = el.getAttribute('data-placeholder-' + lang);
            });
            // select option text
            document.querySelectorAll('select option[data-en][data-it]').forEach(el => {
                el.textContent = el.getAttribute('data-' + lang);
            });
            // nav items
            document.querySelectorAll('[data-en-href][data-it-href]').forEach(el => {
                el.href = el.getAttribute('data-' + lang + '-href');
            });
            const label = document.getElementById('lang-label');
            const labelMobile = document.getElementById('lang-label-mobile');
            const nextLang = lang === 'en' ? 'IT' : 'EN';
            if (label) label.textContent = nextLang;
            if (labelMobile) labelMobile.textContent = nextLang;
            document.documentElement.lang = lang;
            localStorage.setItem('lang', lang);
        }

        function toggleLanguage() {
            const current = localStorage.getItem('lang') || 'en';
            applyLanguage(current === 'en' ? 'it' : 'en');
        }

        function initLanguage() {
            const saved = localStorage.getItem('lang') || 'en';
            applyLanguage(saved);
        }

        domReady(initLanguage);
    </script>
</body>
</html>
