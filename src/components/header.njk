<a class="sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:text-sm focus:rounded-md" style="background-color: var(--card-bg); color: var(--text-primary);" href="#main">Skip to content</a>

{% include "icons.njk" %}

<header style="background-color: rgba(var(--bg-primary-rgb), 0.9); backdrop-filter: blur(4px); border-bottom: 1px solid var(--card-border);" class="sticky top-0 z-50">
  <nav class="container flex items-center justify-between py-4">
    <div class="flex items-center space-x-4">
      <a href="/" class="flex items-center gap-3">
        <img src="/assets/img/ais4i-logo.png" alt="AI Safety for Italy" class="inline-block w-10 h-10">
        <span class="text-lg font-bold" style="color: var(--text-primary);">{{ site.site.name }}</span>
      </a>
    </div>

    <ul class="hidden md:flex items-center space-x-6 text-sm">
      <li><a href="/" class="px-2 py-1 hover:text-accent {% if page.url == '/' %}active{% endif %}" style="color: var(--text-primary);" data-en="{{ translations.en.nav.home }}" data-it="{{ translations.it.nav.home }}">{{ translations.en.nav.home }}</a></li>
      <li><a href="/about/" class="px-2 py-1 hover:text-accent {% if '/about/' == page.url %}active{% endif %}" style="color: var(--text-primary);" data-en="{{ translations.en.nav.about }}" data-it="{{ translations.it.nav.about }}">{{ translations.en.nav.about }}</a></li>
      <li><a href="/initiatives/" class="px-2 py-1 hover:text-accent {% if '/initiatives/' == page.url %}active{% endif %}" style="color: var(--text-primary);" data-en="{{ translations.en.nav.events }}" data-it="{{ translations.it.nav.events }}">{{ translations.en.nav.events }}</a></li>
      <li><a href="/community/" class="px-2 py-1 hover:text-accent {% if '/community/' == page.url %}active{% endif %}" style="color: var(--text-primary);" data-en="{{ translations.en.nav.community }}" data-it="{{ translations.it.nav.community }}">{{ translations.en.nav.community }}</a></li>
      <li><a href="/resources/" class="px-2 py-1 hover:text-accent {% if '/resources/' == page.url %}active{% endif %}" style="color: var(--text-primary);" data-en="{{ translations.en.nav.resources }}" data-it="{{ translations.it.nav.resources }}">{{ translations.en.nav.resources }}</a></li>
      <li><a href="/faq/" class="px-2 py-1 hover:text-accent {% if '/faq/' == page.url %}active{% endif %}" style="color: var(--text-primary);" data-en="{{ translations.en.nav.faq }}" data-it="{{ translations.it.nav.faq }}">{{ translations.en.nav.faq }}</a></li>
      <li><a href="/contact/" class="px-2 py-1 hover:text-accent {% if '/contact/' == page.url %}active{% endif %}" style="color: var(--text-primary);" data-en="{{ translations.en.nav.contact }}" data-it="{{ translations.it.nav.contact }}">{{ translations.en.nav.contact }}</a></li>
    </ul>

    <div class="hidden md:flex items-center space-x-4">
      <a href="{{ site.forms.mailingList }}" target="_blank" class="btn btn-primary" data-en="Join" data-it="Unisciti">Join</a>
      <button id="lang-toggle" class="btn btn-outline" aria-label="Switch language" onclick="toggleLanguage()">
        <span id="lang-label">IT</span>
      </button>
      <button id="theme-toggle" class="btn btn-outline" aria-label="Toggle dark mode">
        <span id="theme-icon">🌙</span>
      </button>
    </div>

    <div class="md:hidden">
      <button id="menuToggle" aria-expanded="false" aria-controls="mobileMenu" class="p-2 rounded-md hover:opacity-75" style="color: var(--text-primary);" onclick="toggleMenu()">
        <span class="sr-only">Open main menu</span>
        ☰
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="hidden md:hidden border-t" style="border-color: var(--card-border); background-color: var(--bg-primary);">
    <div class="px-4 pb-6 pt-2 space-y-1">
      <a href="/" class="block py-2 hover:text-accent" style="color: var(--text-primary);" data-en="{{ translations.en.nav.home }}" data-it="{{ translations.it.nav.home }}">{{ translations.en.nav.home }}</a>
      <a href="/about/" class="block py-2 hover:text-accent" style="color: var(--text-primary);" data-en="{{ translations.en.nav.about }}" data-it="{{ translations.it.nav.about }}">{{ translations.en.nav.about }}</a>
      <a href="/initiatives/" class="block py-2 hover:text-accent" style="color: var(--text-primary);" data-en="{{ translations.en.nav.events }}" data-it="{{ translations.it.nav.events }}">{{ translations.en.nav.events }}</a>
      <a href="/community/" class="block py-2 hover:text-accent" style="color: var(--text-primary);" data-en="{{ translations.en.nav.community }}" data-it="{{ translations.it.nav.community }}">{{ translations.en.nav.community }}</a>
      <a href="/resources/" class="block py-2 hover:text-accent" style="color: var(--text-primary);" data-en="{{ translations.en.nav.resources }}" data-it="{{ translations.it.nav.resources }}">{{ translations.en.nav.resources }}</a>
      <a href="/faq/" class="block py-2 hover:text-accent" style="color: var(--text-primary);" data-en="{{ translations.en.nav.faq }}" data-it="{{ translations.it.nav.faq }}">{{ translations.en.nav.faq }}</a>
      <a href="/contact/" class="block py-2 hover:text-accent" style="color: var(--text-primary);" data-en="{{ translations.en.nav.contact }}" data-it="{{ translations.it.nav.contact }}">{{ translations.en.nav.contact }}</a>
      <a href="{{ site.forms.mailingList }}" target="_blank" class="block mt-3 btn btn-primary text-center" data-en="Join" data-it="Unisciti">Join</a>
      <button onclick="toggleLanguage()" class="block mt-2 btn btn-outline text-center w-full">🌐 <span id="lang-label-mobile">IT</span></button>
    </div>
  </div>
</header>
