<!-- Contact form (two-column: intro + social on the left, form on the right) -->
<section class="section" id="contact-form" style="background-color: var(--bg-primary);">
    <div class="container">
        <div class="contact-grid">
            <!-- Left: intro + social -->
            <div class="reveal">
                <h2 data-en="Got some questions or feedback?" data-it="Hai domande o feedback?">Got some questions or feedback?</h2>
                <p style="max-width: 34ch;"
                   data-en="Feel free to fill out the form. We'd love to hear from you."
                   data-it="Compila il form qui accanto. Ci farebbe piacere sentirti.">Feel free to fill out the form. We'd love to hear from you.</p>

                <h3 class="mt-10 mb-4" data-en="Connect with us:" data-it="Seguici:">Connect with us:</h3>
                <div class="flex gap-3">
                    <a class="social-square" href="{{ site.social.linkedin }}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                    <a class="social-square" href="mailto:{{ site.site.email }}" aria-label="Email">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    </a>
                </div>
            </div>

            <!-- Right: form -->
            <form class="contact-form reveal" onsubmit="return submitContactForm(event)" novalidate>
                <div class="contact-form-row">
                    <div>
                        <label class="form-label" for="cf-name" data-en="Name" data-it="Nome">Name</label>
                        <input id="cf-name" name="name" type="text" required class="form-input"
                               placeholder="Your name" data-placeholder-en="Your name" data-placeholder-it="Il tuo nome">
                    </div>
                    <div>
                        <label class="form-label" for="cf-email" data-en="Email" data-it="Email">Email</label>
                        <input id="cf-email" name="email" type="email" required class="form-input"
                               placeholder="you@email.com" data-placeholder-en="you@email.com" data-placeholder-it="tu@email.com">
                    </div>
                </div>
                <div style="margin-top: 1rem;">
                    <label class="form-label" for="cf-message" data-en="Message" data-it="Messaggio">Message</label>
                    <textarea id="cf-message" name="message" rows="5" required class="form-input"
                              placeholder="Write your message…" data-placeholder-en="Write your message…" data-placeholder-it="Scrivi il tuo messaggio…"></textarea>
                </div>
                <button type="submit" class="btn btn-primary contact-submit"
                        data-en="Send your message" data-it="Invia il messaggio">Send your message</button>
            </form>
        </div>
    </div>
</section>

<script>
    function submitContactForm(e) {
        e.preventDefault();
        var el = e.target.elements;
        var name = (el['name'].value || '').trim();
        var email = (el['email'].value || '').trim();
        var message = (el['message'].value || '').trim();
        if (!name || !email || !message) {
            (!name ? el['name'] : !email ? el['email'] : el['message']).focus();
            return false;
        }
        var subject = encodeURIComponent('Website contact: ' + name);
        var body = encodeURIComponent('Name: ' + name + '\nEmail: ' + email + '\n\n' + message);
        window.location.href = 'mailto:{{ site.site.email }}?subject=' + subject + '&body=' + body;
        return false;
    }
</script>
