<footer class="mt-20">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12 py-16">
      <div>
        <h3 class="font-bold mb-4"
            data-en="{{ translations.en.footer.about_heading }}" data-it="{{ translations.it.footer.about_heading }}">{{ translations.en.footer.about_heading }}</h3>
        <p class="text-sm leading-relaxed opacity-90"
           data-en="{{ translations.en.footer.about_description }}"
           data-it="{{ translations.it.footer.about_description }}">{{ translations.en.footer.about_description }}</p>
      </div>
      <div>
        <h3 class="font-bold mb-4"
            data-en="{{ translations.en.footer.links_heading }}" data-it="{{ translations.it.footer.links_heading }}">{{ translations.en.footer.links_heading }}</h3>
        <ul class="text-sm space-y-3">
          <li><a href="/about/" class="hover:text-accent transition-colors opacity-75 hover:opacity-100"
                 data-en="{{ translations.en.nav.about }}" data-it="{{ translations.it.nav.about }}">{{ translations.en.nav.about }}</a></li>
          <li><a href="/community/" class="hover:text-accent transition-colors opacity-75 hover:opacity-100"
                 data-en="{{ translations.en.nav.community }}" data-it="{{ translations.it.nav.community }}">{{ translations.en.nav.community }}</a></li>
          <li><a href="/resources/" class="hover:text-accent transition-colors opacity-75 hover:opacity-100"
                 data-en="{{ translations.en.nav.resources }}" data-it="{{ translations.it.nav.resources }}">{{ translations.en.nav.resources }}</a></li>
          <li><a href="/contact/" class="hover:text-accent transition-colors opacity-75 hover:opacity-100"
                 data-en="{{ translations.en.nav.contact }}" data-it="{{ translations.it.nav.contact }}">{{ translations.en.nav.contact }}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold mb-4"
            data-en="{{ translations.en.footer.connect_heading }}" data-it="{{ translations.it.footer.connect_heading }}">{{ translations.en.footer.connect_heading }}</h3>
        <ul class="text-sm space-y-3">
          <li>
            <a href="mailto:{{ site.site.email }}" class="hover:text-accent transition-colors opacity-75 hover:opacity-100">
              📧 {{ site.site.email }}
            </a>
          </li>
          <li>
            <a href="{{ site.social.linkedin }}" target="_blank" class="flex items-center gap-2 hover:text-accent transition-colors opacity-75 hover:opacity-100">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t pt-8 text-center text-sm opacity-75" style="border-color: var(--card-border);">
      <p data-en="{{ translations.en.footer.copyright }}" data-it="{{ translations.it.footer.copyright }}">{{ translations.en.footer.copyright }}</p>
    </div>
  </div>
</footer>
